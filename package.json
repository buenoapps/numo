{
  "name": "numo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "eas": "eas",
    "build": "eas build --platform ios",
    "submit": "eas submit --platform ios --latest",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "build:web": "expo export -p web"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.expo/",
      "/dist/"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "expo": "56.0.0-preview.11",
    "expo-audio": "~56.0.5",
    "expo-constants": "~56.0.9",
    "expo-font": "~56.0.3",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.4",
    "expo-linking": "~56.0.6",
    "expo-localization": "~56.0.4",
    "expo-router": "~56.1.4",
    "expo-speech": "~56.0.3",
    "expo-splash-screen": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.4",
    "expo-web-browser": "~56.0.4",
    "i18n-js": "^4.5.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.0",
    "eas-cli": "^18.9.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
